rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // 1. User Rules
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow list: if isAdmin();
      allow create: if isSignedIn() && userId == request.auth.uid &&
                    incoming().userId == request.auth.uid &&
                    incoming().role == 'user';
      allow update: if isSignedIn() && userId == request.auth.uid &&
                    incoming().userId == request.auth.uid &&
                    incoming().updatedAt == request.time;

      match /documents/{docId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // 2. Project Rules
    match /projects/{projectId} {
      allow read: if isSignedIn() && (request.auth.uid == existing().ownerId || request.auth.uid in existing().members || isAdmin());
      allow list: if isSignedIn() && (resource.data.ownerId == request.auth.uid || request.auth.uid in resource.data.members);
      
      allow create: if isSignedIn() &&
                    incoming().ownerId == request.auth.uid &&
                    incoming().createdAt == request.time;
      
      allow update: if isSignedIn() && (
        (request.auth.uid == existing().ownerId || request.auth.uid in existing().members) ||
        isAdmin()
      ) && incoming().updatedAt == request.time;

      allow delete: if isAdmin() || (isSignedIn() && existing().ownerId == request.auth.uid);
    }

    // 3. Activity Rules
    match /activities/{activityId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && incoming().userId == request.auth.uid && incoming().timestamp == request.time;
    }

    // 4. Chat Rules
    match /channels/{channelId}/messages/{messageId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() &&
                    (incoming().userId == request.auth.uid || incoming().userId == 'ghost-assistant') &&
                    incoming().timestamp == request.time;
      allow delete: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
    }

    // 5. Admins Collection
    match /admins/{adminId} {
      allow read: if isSignedIn() && request.auth.uid == adminId;
    }
  }
}
